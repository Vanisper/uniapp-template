{
  "pages": [
    {
      "path": "pages/home/index",
      "type": "home",
      "name": "workbench",
      "style": {
        "mp-alipay": {
          "allowsBounceVertical": "NO"
        },
        "enablePullDownRefresh": true,
        "navigationBarTitleText": "工作台"
      },
      "text": "工作台",
      "icon": "app",
      "tabbar": true
    },
    {
      "path": "pages/about/index",
      "type": "page",
